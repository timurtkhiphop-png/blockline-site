{
  "name": "blockline-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.cjs",
    "dev": "next dev -p 3010 --turbo",
    "dev:webpack": "next dev -p 3010",
    "dev:reset": "npm run clean && next dev -p 3010 --turbo",
    "dev:3000": "next dev -p 3000 --turbo",
    "dev:3001": "next dev -p 3001 --turbo",
    "build": "node scripts/build-export-lite.cjs",
    "build:full": "node scripts/build-full.cjs",
    "build:export": "node scripts/build-export-lite.cjs",
    "build:clean": "npm run clean && npm run build",
    "build:docker": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-export.ps1",
    "out:full": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-timeweb.ps1 -Full",
    "out": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-timeweb.ps1",
    "out:zip": "powershell -ExecutionPolicy Bypass -File ./scripts/zip-out.ps1",
    "out:tar": "powershell -ExecutionPolicy Bypass -File ./scripts/tar-out.ps1",
    "source:pack": "powershell -ExecutionPolicy Bypass -File ./scripts/pack-source.ps1",
    "timeweb:pack": "npm run out",
    "timeweb:pack:full": "npm run out:full",
    "start": "npx --yes serve@14 out -l 3010",
    "preview": "npm run start",
    "start:out": "npx --yes serve@14 out -l 3000",
    "start:node": "npm run start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.184.0",
    "framer-motion": "^11.15.0",
    "gsap": "^3.12.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
